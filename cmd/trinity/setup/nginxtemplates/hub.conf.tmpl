# Trinity hub nginx vhost. Rendered by setup.RenderHubNginxConfig and
# installed by scripts/bootstrap-nginx.sh --mode=hub. Carries:
#   - HTTP→HTTPS redirect for {{ .PublicHost }}
#   - HTTPS server with SPA + api/ws + asset fallbacks
#   - dl.{{ .PublicHost }} fastdl vhost (HTTP + HTTPS)
#
# Cert paths assume Let's Encrypt's standard layout. The wizard arranges
# for /etc/letsencrypt/live/{{ .PublicHost }}/ to exist before nginx is
# (re)loaded with this config. SAN cert covers both {{ .PublicHost }}
# and dl.{{ .PublicHost }}.

server {
    listen 80;
    listen [::]:80;
    server_name {{ .PublicHost }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ .PublicHost }};

    ssl_certificate     /etc/letsencrypt/live/{{ .PublicHost }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ .PublicHost }}/privkey.pem;

    root {{ .StaticDir }};
    index index.html;

    # Asset paths that may exist locally OR live on a remote source. nginx
    # serves the file when present; on miss it falls back to the trinity
    # Go binary, which 302s to the source that owns the asset.
    location /demos/                { try_files $uri @trinity_fallback; }
    location /assets/levelshots/    { try_files $uri @trinity_fallback; }
    location /demopk3s/maps/        { try_files $uri @trinity_fallback; }
    location @trinity_fallback {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # /q3/ exposes pak/tvd files from {{ .Quake3Dir }} for the in-browser
    # engine (demo player + live client). pak0 is forbidden (id Software
    # content, not redistributable); anything other than pk3/tvd is denied.
    location ~ ^/q3/(baseq3|missionpack)/pak0\.pk3$ {
        return 403;
    }
    location ~ ^/q3/(.+\.(pk3|tvd))$ {
        alias {{ .Quake3Dir }}/$1;
    }
    location /q3/ {
        return 403;
    }

    # Vite content-hashed bundles (assets/index-<hash>.js|css). Filename
    # changes whenever content changes, so cache forever. The longer-
    # prefix /assets/levelshots/ block above wins for that subtree.
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    # index.html references those hashed bundle names. Must revalidate
    # every load so a deploy can't strand users on a stale reference.
    location = /index.html {
        add_header Cache-Control "no-cache" always;
    }

    # SPA fallback. Real files (favicon, /flags/, /modes/, /videos/,
    # /vr/, trinity.{html,js,wasm}, etc.) keep nginx's default — browser
    # heuristic caching is fine for them.
    location / {
        try_files $uri $uri/ @spa;
    }
    location @spa {
        add_header Cache-Control "no-cache" always;
        rewrite ^ /index.html last;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /ws {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400;
    }
}

# Quake 3 fast-downloads.
server {
    listen 80;
    listen [::]:80;
    server_name dl.{{ .PublicHost }};

    root {{ .Quake3Dir }};

    location ~ ^/(baseq3|missionpack)/pak0\.pk3$ {
        return 403;
    }
    location ~ \.(pk3|tvd)$ {
        try_files $uri =404;
    }
    location / {
        return 403;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name dl.{{ .PublicHost }};

    ssl_certificate     /etc/letsencrypt/live/{{ .PublicHost }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ .PublicHost }}/privkey.pem;

    root {{ .Quake3Dir }};

    location ~ ^/(baseq3|missionpack)/pak0\.pk3$ {
        return 403;
    }
    location ~ \.(pk3|tvd)$ {
        try_files $uri =404;
    }
    location / {
        return 403;
    }
}
